# ══════════════════════════════════════════════════════════════════════════════
# Python
# ══════════════════════════════════════════════════════════════════════════════
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Entornos virtuales
.venv/
venv/
env/

# Distribución / empaquetado
dist/
build/
*.egg-info/
*.egg

# Caché de herramientas
.mypy_cache/
.ruff_cache/
.pytest_cache/
.cache/

# ══════════════════════════════════════════════════════════════════════════════
# Jupyter
# ══════════════════════════════════════════════════════════════════════════════
.ipynb_checkpoints/
*.ipynb_checkpoints

# ══════════════════════════════════════════════════════════════════════════════
# LaTeX — artefactos de compilación
# ══════════════════════════════════════════════════════════════════════════════
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.idx
*.ilg
*.ind
*.lof
*.log
*.lot
*.nav
*.run.xml
*.snm
*.synctex.gz
*.synctex(busy)
*.toc
*.vrb

# Directorio de salida de compilación (PDFs generados por LaTeX)
# Para añadir un PDF compilado manualmente: git add -f ruta/out/archivo.pdf
**/out/

# ══════════════════════════════════════════════════════════════════════════════
# Simulación — salidas generadas
# ══════════════════════════════════════════════════════════════════════════════
*.gif
*.mp4
*.avi

# ══════════════════════════════════════════════════════════════════════════════

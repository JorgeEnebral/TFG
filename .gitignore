# ══════════════════════════════════════════════════════════════════════════════
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ══════════════════════════════════════════════════════════════════════════════
# IDEs y editores
# ══════════════════════════════════════════════════════════════════════════════
# VS Code (ignorar configuración local de usuario, conservar settings del proyecto)
.vscode/*.log

# JetBrains
.idea/

